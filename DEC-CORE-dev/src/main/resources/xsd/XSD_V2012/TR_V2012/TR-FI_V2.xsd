<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified">
    <xs:simpleType name="T_Date">
        <xs:restriction base="xs:string">
            <xs:pattern value="(0[1-9]|[1-2][0-9]|3[0-1])/(0[1-9]|1[0-2])/\d{4}"/>
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="Devise">
        <xs:restriction base="xs:string">
            <xs:pattern value="[0-9]{3,3}"/>
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="T_Mnt_Devise">
        <xs:restriction base="xs:decimal">
            <xs:totalDigits value="17"/>
            <xs:fractionDigits value="3"/>
        </xs:restriction>
    </xs:simpleType>
    <xs:complexType name="T_Montant">
        <xs:simpleContent>
            <xs:extension base="T_Mnt_Devise">
                <xs:attribute name="Ccy" type="Devise" use="required"/>
            </xs:extension>
        </xs:simpleContent>
    </xs:complexType>
    <xs:element name="Document">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="EnteteDoc">
                    <xs:complexType>
                        <xs:sequence>
                            <xs:element name="CodeIAT" minOccurs="1">
                                <xs:annotation>
                                    <xs:documentation source="Name" xml:lang="Fr">Code IAT</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:pattern value="\d{2}"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element name="DateDec" type="T_Date" minOccurs="1">
                                <xs:annotation>
                                    <xs:documentation source="Name" xml:lang="Fr">Date de déclaration</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element name="CodeAnnexe" minOccurs="1">
                                <xs:annotation>
                                    <xs:documentation source="Name" xml:lang="Fr">Code Annexe</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:pattern value="[A-Z]{2}-[0-9]{3}"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                        </xs:sequence>
                    </xs:complexType>
                </xs:element>
                <xs:element name="Transferts">
                    <xs:complexType>
                        <xs:sequence>
                            <xs:element name="Transfert" maxOccurs="unbounded">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element name="Entete">
                                            <xs:complexType>
                                                <xs:sequence>
												  <xs:element name="AnneDec" minOccurs="1">
													<xs:annotation>
														<xs:documentation source="Name" xml:lang="Fr">Année de déclaration du fichier à la BCT</xs:documentation>
													</xs:annotation>   
												    <xs:simpleType>
												  	<xs:restriction base="xs:string">
												  		<xs:pattern value="\d{4}"/>
												  	</xs:restriction>	
												    </xs:simpleType>
                                                  </xs:element>
												  <xs:element name="MoisDec" minOccurs="1">
													<xs:annotation>
														<xs:documentation source="Name" xml:lang="Fr">Mois de déclaration du fichier  à la BCT</xs:documentation>
													</xs:annotation>   
												    <xs:simpleType>
												  	<xs:restriction base="xs:string">
												  		<xs:pattern value="\d{2}"/>
												  	</xs:restriction>	
												    </xs:simpleType>
                                                  </xs:element>
												  <xs:element name="PeriodDec" minOccurs="1">
													<xs:annotation>
														<xs:documentation source="Name" xml:lang="Fr">N° de la quinzaine du mois de declaration </xs:documentation>
													</xs:annotation>   
												    <xs:simpleType>
												  	<xs:restriction base="xs:integer">
													<xs:pattern value="[1-2]"/>
												  	</xs:restriction>	
												    </xs:simpleType>
                                                  </xs:element>											
                                                  <xs:element name="NbrEcritures" minOccurs="1">
													<xs:annotation>
														<xs:documentation source="Name" xml:lang="Fr"> Nombre de ligne de l'enregistrement détail</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
													  <xs:restriction base="xs:string">
														<xs:pattern value="\d{6}"/>
													  </xs:restriction>
													</xs:simpleType>
                                                  </xs:element>
                                                </xs:sequence>
                                            </xs:complexType>
                                        </xs:element>
                                        <xs:element name="Details">
                                            <xs:complexType>
                                                <xs:sequence>
                                                  <xs:element name="Detail" maxOccurs="unbounded">
													<xs:complexType>
														<xs:sequence>
															 
															    <xs:element name="AnneDec" minOccurs="1">
																<xs:annotation>
																	<xs:documentation source="Name" xml:lang="Fr">Année de déclaration du fichier à la BCT</xs:documentation>
																</xs:annotation>   
																<xs:simpleType>
																<xs:restriction base="xs:string">
																	<xs:pattern value="\d{4}"/>
																</xs:restriction>	
																</xs:simpleType>
															  </xs:element>
															  <xs:element name="MoisDec" minOccurs="1">
																<xs:annotation>
																	<xs:documentation source="Name" xml:lang="Fr">Mois de déclaration du fichier  à la BCT</xs:documentation>
																</xs:annotation>   
																<xs:simpleType>
																<xs:restriction base="xs:string">
																	<xs:pattern value="\d{2}"/>
																</xs:restriction>	
																</xs:simpleType>
															  </xs:element>
															  <xs:element name="PeriodDec" minOccurs="1">
																<xs:annotation>
																	<xs:documentation source="Name" xml:lang="Fr">N° de la quinzaine du mois de declaration </xs:documentation>
																</xs:annotation>   
																<xs:simpleType>
																<xs:restriction base="xs:integer">
																<xs:pattern value="[1-2]"/>
																</xs:restriction>	
																</xs:simpleType>
															  </xs:element>	
															  <xs:element name="Agence" minOccurs="1">
																<xs:annotation>
																	<xs:documentation source="Name" xml:lang="Fr">Agence a effectué le transfert</xs:documentation>
																</xs:annotation>
																<xs:simpleType>
																  <xs:restriction base="xs:string">
																	<xs:pattern value="\d{3}"/>
																  </xs:restriction>
																</xs:simpleType>
															  </xs:element>	
															   <xs:element name="CodTitre" minOccurs="1">
																<xs:annotation>
																	<xs:documentation source="Name" xml:lang="Fr">Code titre de l'oprération de transfert</xs:documentation>
																</xs:annotation>
																<xs:simpleType>
																  <xs:restriction base="xs:string">
																  	<xs:enumeration value="73">
																  		<xs:annotation>
																  			<xs:documentation>73 = Pour les transferts réalisés par les autres opérateurs résidents</xs:documentation>
																  		</xs:annotation>
																  	</xs:enumeration>
																  	<xs:enumeration value="78">
																  		<xs:annotation>
																  			<xs:documentation>78 = Pour les transferts réalisés par les entreprises totalement exportatrices résidentes au titre de l'acquisition de biens ou de services.
																  			</xs:documentation>
																  		</xs:annotation>
																  	</xs:enumeration>
																  </xs:restriction>
																</xs:simpleType>
															  </xs:element>	
															  <xs:element name="RefFichInfo">
																<xs:complexType>
																	<xs:sequence>																																			
																		<xs:element name="RefFichInfo" minOccurs="0">
																			<xs:annotation>
																				<xs:documentation source="Name" xml:lang="Fr">Reference fiche d'information </xs:documentation>
																		    </xs:annotation>
																			<xs:simpleType>
																			<xs:union>
																		    <xs:simpleType>																			
																			  <xs:restriction base="xs:string">
																				<xs:length value="7"/> 
																			   </xs:restriction>					   
																		     </xs:simpleType>
																			 <xs:simpleType>
																			  <xs:restriction base="xs:string">
																				  <xs:length value="0"/> 
																			  </xs:restriction> 
																			 </xs:simpleType> 																			
																			</xs:union>
																			</xs:simpleType>
																		</xs:element>
																	    <xs:element name="DatFichInfo" minOccurs="0">
																			<xs:annotation>
																				<xs:documentation source="Name" xml:lang="Fr">Date de l'etablissement de la fiche d'information</xs:documentation>
																			</xs:annotation>
																			 <xs:simpleType>
																				<xs:union>
																			    <xs:simpleType>
																					<xs:restriction base="T_Date" >
																					
																					</xs:restriction>
																				</xs:simpleType>
																				<xs:simpleType>
																			  <xs:restriction base="xs:string">
																				  <xs:length value="0"/> 
																			  </xs:restriction> 
																			 </xs:simpleType> 																			
																			</xs:union>
																			</xs:simpleType>
																		</xs:element> 
																		
																	</xs:sequence>														
																</xs:complexType>
															   </xs:element>
															    <xs:element name="DatTrans" type='T_Date' minOccurs="1">
																			<xs:annotation>
																				<xs:documentation source="Name" xml:lang="Fr">Date de transfert</xs:documentation>
																			</xs:annotation>
																		
															  </xs:element>
															   	<xs:element name="Demandeur">
																<xs:complexType>
																	<xs:sequence>																																			
																		<xs:element name="TypeIdentifiant" minOccurs="1">
																			<xs:annotation>
																				<xs:documentation source="Name" xml:lang="Fr">Type identifiant demandeur</xs:documentation>
																			</xs:annotation>
																			<xs:simpleType>
																			  <xs:restriction base="xs:string">
																				  <xs:enumeration value="C">
																					  <xs:annotation>
																						<xs:documentation>C = CIN </xs:documentation>
																					  </xs:annotation>
																				  </xs:enumeration>
																				  <xs:enumeration value="P">
																					  <xs:annotation>
																						<xs:documentation>P = Passeport</xs:documentation>
																					  </xs:annotation>
																				  </xs:enumeration>
																				  <xs:enumeration value="S">
																					  <xs:annotation>
																						<xs:documentation>S = Carte de séjour</xs:documentation>
																					  </xs:annotation>
																				  </xs:enumeration>
																				  <xs:enumeration value="D">
																					  <xs:annotation>
																						<xs:documentation>D = Identifiant unique</xs:documentation>
																					  </xs:annotation>
																				  </xs:enumeration>
																				  <xs:enumeration value="F">
																					  <xs:annotation>
																						<xs:documentation>F = Code financier </xs:documentation>
																					  </xs:annotation>
																				  </xs:enumeration>
																				  
																			   </xs:restriction>
																			</xs:simpleType>
																		</xs:element>
																	    <xs:element name="CodIdentifiant" minOccurs="1">
																			<xs:annotation>
																				<xs:documentation source="Name" xml:lang="Fr">Identifiant demandeur </xs:documentation>
																			</xs:annotation>
																				<xs:simpleType>
																					<xs:restriction base="xs:string" >
																						<xs:maxLength value="15"/>
																					</xs:restriction>
																				</xs:simpleType>
																		</xs:element> 
																		<xs:element name="Nom" minOccurs="0">
																			<xs:annotation>
																				<xs:documentation source="Name" xml:lang="Fr">Nom opérateur </xs:documentation>
																			</xs:annotation>
																			 <xs:simpleType>
																				<xs:restriction base="xs:string">
																					<xs:maxLength value="30"/>
																				</xs:restriction>
																			</xs:simpleType>
																		</xs:element> 
																		
																		<xs:element name="Prenom" minOccurs="0">
																			<xs:annotation>
																				<xs:documentation source="Name" xml:lang="Fr">Prenom opérateur</xs:documentation>
																			</xs:annotation>
																			 <xs:simpleType>
																				<xs:restriction base="xs:string">
																					<xs:maxLength value="30"/>
																				</xs:restriction>
																		  </xs:simpleType>
																			
																		</xs:element> 
																		<xs:element name="DenomDem" minOccurs="0">
																			<xs:annotation>
																				<xs:documentation source="Name" xml:lang="Fr">Dénomination de l'opérateur</xs:documentation>
																			</xs:annotation>	
																			<xs:simpleType>
																			<xs:restriction base="xs:string">
																				<xs:maxLength value="80"/>
																			</xs:restriction>
																		  </xs:simpleType>
																		</xs:element> 	
																			
																	</xs:sequence>														
																</xs:complexType>
															   </xs:element>
															  <xs:element name="OperationTransf" minOccurs="1">
																<xs:complexType>
																	<xs:sequence>
																	  <xs:element name="MntTransDev" type="T_Montant" minOccurs="1">
																		   <xs:annotation>
																				<xs:documentation source="Name" xml:lang="Fr">Montant du transfert  </xs:documentation>
																		  </xs:annotation>																		 																		  
																																				  
																	 </xs:element>
																	  <xs:element name="CvMntTnd" type="T_Montant" minOccurs="1">
																		  <xs:annotation>
																			<xs:documentation source="Name" xml:lang="Fr">CV en TND du montant du transfert</xs:documentation>
																		  </xs:annotation>									  
																	  </xs:element>
																	   <xs:element name="ModReg"   minOccurs="1">
																		  <xs:annotation>
																			<xs:documentation source="Name" xml:lang="Fr">Mode de reglement </xs:documentation>
																		  </xs:annotation>
																		   <xs:simpleType> 
																				<xs:restriction base="xs:string" > 
																					<xs:enumeration value="15">
																						<xs:annotation>
																							<xs:documentation>15 = En cas de transfert en espèce </xs:documentation>
																						</xs:annotation>
																					</xs:enumeration>
																					<xs:enumeration value="21">
																						<xs:annotation>
																							<xs:documentation>21 = En cas de transfert par virement  </xs:documentation>
																						</xs:annotation>
																					</xs:enumeration>
																					<xs:enumeration value="22">
																						<xs:annotation>
																							<xs:documentation>22 = En cas de transfert par chèque  </xs:documentation>
																						</xs:annotation>
																					</xs:enumeration>
																				</xs:restriction>
																			  </xs:simpleType> 
																		  										
																	  </xs:element>
																	  <xs:element name="CodReg"  minOccurs="1">
																		  <xs:annotation>
																			<xs:documentation source="Name" xml:lang="Fr">Code de règlement</xs:documentation>
																		  </xs:annotation>
																			 <xs:simpleType> 
																				<xs:restriction base="xs:string" > 
																					<xs:enumeration value="10">
																						<xs:annotation>
																							<xs:documentation>10 =  En cas de transfert par achat de devises  </xs:documentation>
																						</xs:annotation>
																					</xs:enumeration>
																					<xs:enumeration value="20">
																						<xs:annotation>
																							<xs:documentation>20 = En cas de transfert par débit du compte professionnel  </xs:documentation>
																						</xs:annotation>
																					</xs:enumeration>
																					<xs:enumeration value="40">
																						<xs:annotation>
																							<xs:documentation>40 =  En cas de crédit de comptes de non-résidents en dinars convertibles par des dinars intérieurs. </xs:documentation>
																						</xs:annotation>
																					</xs:enumeration>
																					<xs:enumeration value="50">
																						<xs:annotation>
																							<xs:documentation>50 = En cas de débit d'autres comptes en devises ou en dinars convertibles de résidents </xs:documentation>
																						</xs:annotation>
																					</xs:enumeration>
																				</xs:restriction>
																			  </xs:simpleType> 
																	  </xs:element>
																	  <xs:element name="RefMsgSwift" minOccurs="0">
																		  <xs:annotation>
																			<xs:documentation source="Name" xml:lang="Fr">Reference message SWIFT du transfert  </xs:documentation>
																		  </xs:annotation>
																		   <xs:simpleType>
																			<xs:restriction base="xs:string">
																				<xs:maxLength value="20"/>
																			</xs:restriction>
																		  </xs:simpleType>																																																					
																	  </xs:element>						
														
															<xs:element name="CodBenif" minOccurs="1">
																<xs:annotation>
																	<xs:documentation source="Name" xml:lang="Fr">Code bénéficiaire</xs:documentation>
																</xs:annotation>
																<xs:simpleType>
																	<xs:restriction base="xs:string">
																		<xs:maxLength value="15"/>
																	</xs:restriction>
																</xs:simpleType>
															</xs:element>
															<xs:element name="NomPrenomDenomBenif" minOccurs="1">
																<xs:annotation>
																	<xs:documentation source="Name" xml:lang="Fr">Nom Prenom / Dénomination du bénéficiaire </xs:documentation>
																</xs:annotation>
																<xs:simpleType>
																	<xs:restriction base="xs:string">
																		<xs:maxLength value="80"/>
																	</xs:restriction>
																</xs:simpleType>
															</xs:element>
																<xs:element name="NatOp" minOccurs="1">
																<xs:annotation>
																	<xs:documentation source="Name" xml:lang="Fr">Code nature opération</xs:documentation>
																</xs:annotation> 																			
																	<xs:simpleType>
																		<xs:restriction base="xs:string">
																			<xs:pattern value="\d{4}"/>
																		</xs:restriction>
																	</xs:simpleType>															
															</xs:element>
															<xs:element name="CodPaysDest" minOccurs="1">
																<xs:annotation>
																	<xs:documentation source="Name" xml:lang="Fr">Code pays de destination du transfert</xs:documentation>
																</xs:annotation>
																<xs:simpleType>
																	<xs:restriction base="xs:string">
																		<xs:pattern value="\d{3}"/>
																	</xs:restriction>
																</xs:simpleType>
															</xs:element>
																					  
																	</xs:sequence>
																</xs:complexType>
															</xs:element>
												  
														</xs:sequence>
													</xs:complexType>
												</xs:element>
                                                </xs:sequence>
                                            </xs:complexType>
                                        </xs:element>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                        </xs:sequence>
                    </xs:complexType>
                </xs:element>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

</xs:schema>
